

<div class="cards-container">

  <div class="card" onclick="flipCard(this)">
    <div class="card-inner">
      
      <div class="card-front">
        <img src="assets/eevee-sar.png" alt="Eevee ex SAR">
      </div>
      
      <div class="card-back">
        <h3 class="card-title" 
            data-ja="イーブイ ex" 
            data-en="Eevee ex" 
            data-es="Eevee ex">Eevee ex</h3>
        <p class="card-collection">Terastal Fest ex SAR</p>
      </div>

    </div>
  </div>

</div>







/* Contenedor de la cuadrícula de cartas */
.cards-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 20px;
  padding: 20px;
}

/* El elemento base de la carta define el espacio y la perspectiva del entorno 3D */
.card {
  background-color: transparent;
  width: 200px;
  height: 280px;
  perspective: 1000px; /* ¡IMPORTANTE! Da el efecto de profundidad 3D al girar */
  cursor: pointer;
}

/* Este contenedor intermedio es el que realmente rota en el espacio */
.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  text-align: center;
  transition: transform 0.6s ease-in-out; /* Controla la velocidad del giro */
  transform-style: preserve-3d; /* Obliga a los hijos a mantener sus planos 3D */
}

/* Esta clase se añadirá dinámicamente con JavaScript al hacer clic */
.card.is-flipped .card-inner {
  transform: rotateY(180deg); /* Gira la carta 180 grados sobre el eje Vertical */
}

/* Reglas comunes para ambas caras de la carta */
.card-front, .card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  -webkit-backface-visibility: hidden; /* Soporte navegadores antiguos */
  backface-visibility: hidden; /* ¡CLAVE! Oculta la cara que queda detrás */
  border-radius: 10px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

/* Estilo específico de la cara frontal */
.card-front {
  background-color: #111;
}
.card-front img {
  width: 100%;
  height: 100%;
  border-radius: 10px;
  object-fit: cover;
}

/* Estilo específico de la cara trasera (información) */
.card-back {
  background-color: #1a4a3a; /* Color verdoso temático Terastal Fest */
  color: white;
  transform: rotateY(180deg); /* Nace ya volteada para que al girar la carta se vea al derecho */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 10px;
}







// 1. FUNCIÓN PARA VOLTEAR LAS CARTAS
// Al usar 'this' en el HTML, recibimos directamente la carta clickeada
function flipCard(cardElement) {
    // toggle() añade la clase si no existe, o la quita si ya existe.
    // Esto permite dar la vuelta y regresar la carta a su estado original.
    cardElement.classList.toggle('is-flipped');
}

// 2. SISTEMA DINÁMICO DE IDIOMAS (JA, EN, ES)
function changeLanguage(lang) {
    // Buscamos todos los elementos de texto que tengan datos de traducción
    const elementsToTranslate = document.querySelectorAll('[data-es]');
    
    elementsToTranslate.forEach(element => {
        // Leemos el atributo correspondiente al idioma seleccionado (data-es, data-en, data-ja)
        const translatedText = element.getAttribute(`data-${lang}`);
        
        if (translatedText) {
            element.textContent = translatedText;
        }
    });
    
    // Opcional: Puedes guardar la elección del usuario en el navegador
    localStorage.setItem('preferredLang', lang);
}

// Al cargar la página, verificamos si ya había un idioma guardado anteriormente
document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('preferredLang') || 'es'; // Por defecto español
    changeLanguage(savedLang);
});